# Shared local environment for the portfolio repo.
# Copy this file to `.env` and replace placeholder values where needed.

# Backend runtime
ASPNETCORE_ENVIRONMENT=Development
ASPNETCORE_URLS=http://localhost:5000
AllowedHosts=*
ConnectionStrings__DefaultConnection=Host=localhost;Port=5432;Database=portfolio_db;Username=postgres;Password=postgres
PORTFOLIO_ADMIN_TOKEN=change-this-to-a-strong-admin-token

# Frontend runtime
VITE_API_URL=http://localhost:5000
VITE_API_BASE_URL=http://localhost:5000
VITE_API_PROXY_TARGET=http://localhost:5000
